# Copy this file to .env and fill your values. Never commit .env.

# MCP Server (required for HTTP)
MCP_TRANSPORT=streamable-http
HTTP_PORT=8000

# Auth (optional - set for production / secure testing)
# MCP_BEARER_TOKEN=your-secret-token

# --- External API (Phase 3) - DocContext ---
# Set these to see DocContext tools in MCP Inspector / n8n
# DOCCONTEXT_API_URL=http://your-doccontext-host:85
# DOCCONTEXT_API_TOKEN=optional-if-api-needs-auth

# --- Fake API for testing (optional) - proves external tools work ---
# TEST_ECHO_API_URL=https://httpbin.org

# --- Database (optional - for get_file_metadata, search_files, semantic_search) ---
# DATABASE_URL=postgresql://user:pass@host:5432/db
# VECTOR_PROVIDER=mock
# PGVECTOR_ENABLED=false
# OLLAMA_URL=
# OLLAMA_EMBEDDING_MODEL=llama3.2
